{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // "moduleResolution": "node"
  }
}
