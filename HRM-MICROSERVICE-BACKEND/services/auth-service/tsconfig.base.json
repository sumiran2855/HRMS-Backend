{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "noImplicitAny": false,
    "strictNullChecks": false,
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "resolveJsonModule": true,
    "declaration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "allowJs": true,
    "checkJs": false
  }
}
