              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hrms.com\",\n  \"password\": \"AdminPass@123\",\n  \"name\": \"Admin User\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
