        {
          "name": "5. Login as Admin - Get Token with Permissions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('admin_token', jsonData.accessToken);",
